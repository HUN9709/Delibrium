# Default: built-in FakePanelist, runs with no API keys.
PANELIST_ID=fake-panelist
PANELIST_TYPE=fake
PROVIDER=fake
MODEL_NAME=fake-1
DATABASE_URL=sqlite+aiosqlite:///./panelist.db
MAX_HISTORY_MESSAGES=30
LLM_TIMEOUT_SECONDS=60
DEFAULT_MAX_OUTPUT_TOKENS=4096

# --- Claude panelist (Milestone 2) ---
# To run as a real Claude server, set:
#   PANELIST_TYPE=claude
#   PROVIDER=anthropic
#   MODEL_NAME=claude-sonnet-4-6   (or another current model id)
#   ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=

# Unused until later milestones.
OPENAI_API_KEY=
GEMINI_API_KEY=
